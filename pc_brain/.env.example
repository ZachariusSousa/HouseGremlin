ROBIT_BASE_URL=http://192.168.4.1
ROBIT_REQUEST_TIMEOUT=2.0

ROBIT_LLM_PROVIDER=ollama
ROBIT_LLM_BASE_URL=http://localhost:11434
ROBIT_LLM_MODEL=gemma4:e4b
ROBIT_LLM_THINK=false
ROBIT_LLM_TIMEOUT=30.0

ROBIT_STT_PROVIDER=faster_whisper
ROBIT_STT_MODEL=base
ROBIT_STT_DEVICE=cuda
ROBIT_STT_COMPUTE_TYPE=float16

ROBIT_TTS_PROVIDER=xtts
ROBIT_TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
ROBIT_TTS_LANGUAGE=en
ROBIT_TTS_DEVICE=cuda
ROBIT_VOICE_ID=default

ROBIT_DATA_DIR=./data
ROBIT_WARM_MODELS=true
