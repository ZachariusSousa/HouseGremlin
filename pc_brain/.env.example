ROBIT_BASE_URL=http://robit.local
ROBIT_REQUEST_TIMEOUT=2.0
ROBIT_LLM_MAX_SPEED=180
ROBIT_LLM_DEFAULT_SPEED=170
ROBIT_LLM_MAX_DURATION_MS=1000

ROBIT_LLM_PROVIDER=openai_compatible
ROBIT_LLM_BASE_URL=http://127.0.0.1:8081/v1
ROBIT_LLM_MODEL=ggml-org/gemma-4-E4B-it-GGUF:Q4_0
ROBIT_LLM_THINK=false
ROBIT_LLM_TIMEOUT=30.0

ROBIT_REALTIME_WS_URL=ws://localhost:7861/v1/realtime
ROBIT_REALTIME_VOICE=serena
ROBIT_REALTIME_INSTRUCTIONS=You are Robit, a small helpful home robot. Talk like Rocky from Project Hail Mary. Be concise and use plain spoken text only. You can call the robot_action tool for safe movement, head, eye, or emergency-stop actions when the user asks.

ROBIT_DATA_DIR=./data
ROBIT_WARM_MODELS=true

ROBIT_VISION_ENABLED=true
ROBIT_VISION_BASE_URL=http://127.0.0.1:8081/v1
ROBIT_VISION_MODEL=ggml-org/gemma-4-E4B-it-GGUF:Q4_0
ROBIT_VISION_REQUEST_TIMEOUT_SECONDS=30
ROBIT_VISION_MAX_OUTPUT_TOKENS=320
ROBIT_VISION_IMAGE_TOKENS=140
ROBIT_VISION_AWARENESS_INTERVAL_SECONDS=5
ROBIT_VISION_SNAPSHOT_TTL_SECONDS=10
ROBIT_VISION_WORLD_WINDOW_SECONDS=60
ROBIT_VISION_CHANGE_THRESHOLD=0.03
ROBIT_VISION_BLUR_THRESHOLD=20
ROBIT_CAMERA_FRAME_INTERVAL_SECONDS=5
ROBIT_CAMERA_ROTATE_DEGREES=180

ROBIT_TRACKING_ENABLED=true
ROBIT_TRACKING_BASE_URL=http://127.0.0.1:8091
ROBIT_TRACKING_REQUEST_TIMEOUT_SECONDS=2
ROBIT_TRACKING_CONFIDENCE=0.40
ROBIT_TRACKING_PAN_SIGN=1
ROBIT_TRACKING_TILT_SIGN=1
